# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres connection string, from your Supabase project:
# Dashboard > Connect > Connection string (URI). Use the "Session pooler"
# string on IPv4-only networks (most home connections). REQUIRED — the
# server refuses to start without it.
DATABASE_URL=postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Google OAuth (Jarvis mode). Create a Web application client in Google Cloud
# Console (Calendar + Gmail + People APIs enabled, OAuth consent screen set to
# External with yourself as a test user) — see the Jarvis build plan, Phase 0.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# Fernet key (32 url-safe base64 bytes) encrypting stored Google tokens at
# rest. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=xxxx

# HMAC secret for OAuth state (authorize → callback). MUST be distinct from
# GOOGLE_TOKEN_ENCRYPTION_KEY — do not reuse the Fernet key. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH_STATE_SECRET=xxxx
