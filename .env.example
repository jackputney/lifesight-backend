# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres connection string, from your Supabase project:
# Dashboard > Connect > Connection string (URI). Use the "Session pooler"
# string on IPv4-only networks (most home connections). REQUIRED — the
# server refuses to start without it.
DATABASE_URL=postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
